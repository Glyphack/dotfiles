FROM node:20

RUN apt-get update && apt-get install -y --no-install-recommends \
  less \
  git \
  procps \
  sudo \
  fzf \
  zsh \
  man-db \
  unzip \
  gnupg2 \
  gh \
  jq \
  nano \
  vim \
  tmux \
  curl \
  ca-certificates \
  openjdk-17-jdk \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

ARG NVIM_VERSION=0.12.4
RUN arch="$(dpkg --print-architecture)" && \
  case "$arch" in \
    arm64) nvim_arch=arm64 ;; \
    amd64) nvim_arch=x86_64 ;; \
    *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
  esac && \
  curl -fsSL "https://github.com/neovim/neovim/releases/download/v${NVIM_VERSION}/nvim-linux-${nvim_arch}.tar.gz" -o /tmp/nvim.tar.gz && \
  tar -C /opt -xzf /tmp/nvim.tar.gz && \
  mv "/opt/nvim-linux-${nvim_arch}" /opt/nvim && \
  ln -s /opt/nvim/bin/nvim /usr/local/bin/nvim && \
  rm /tmp/nvim.tar.gz

ARG GIT_DELTA_VERSION=0.18.2
ENV SHELL=/bin/zsh
ENV EDITOR=vim
ENV VISUAL=vim

RUN curl -fsSL https://raw.githubusercontent.com/databricks/setup-cli/main/install.sh | sh

# claude does not run with --dangerously-skip-permissions on sudo
RUN echo 'node ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/node-nopasswd && \
  chmod 0440 /etc/sudoers.d/node-nopasswd
RUN mkdir -p /home/node/.claude /home/node/.config/gh /workspace && \
  chown -R node:node /home/node /workspace
USER node
WORKDIR /home/node

ENV PATH="/home/node/.local/bin:/home/node/.local/share/mise/shims:/home/node/.cargo/bin:$PATH"
ENV MISE_TRUSTED_CONFIG_PATHS=/

RUN curl https://mise.run | sh
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
RUN curl -fsSL https://claude.ai/install.sh | bash
RUN curl -fsSL batrachian.ai/install | sh
RUN curl -fsSL https://opencode.ai/install | bash

# RUN cargo install cargo-nextest --locked

RUN git config --global init.templateDir '' && \
  git config --global safe.directory /workspace

RUN echo 'alias claude="claude --dangerously-skip-permissions"' >> /home/node/.bashrc && \
  echo 'alias claude="claude --dangerously-skip-permissions"' >> /home/node/.zshrc && \
  echo 'eval "$(mise activate bash)"' >> /home/node/.bashrc && \
  echo 'eval "$(mise activate zsh)"' >> /home/node/.zshrc

WORKDIR /workspace
CMD ["/bin/zsh"]
